{"_id": "rt_t001", "name": "Void Acclimatised", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "-", "aptitudes": ["Agility", "Fieldcraft"], "tier": 1, "description": "Reduce all zero-gravity movement penalties by 20. +10 Operate (Voidship) and Navigate (Stellar).", "benefit": "Prerequisites: - | Tier 1 | Aptitudes: Agility, Fieldcraft"}}
{"_id": "rt_t002", "name": "Peer (Underworld)", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Fel 30", "aptitudes": ["Fellowship", "Social"], "tier": 1, "description": "+10 Fellowship tests with criminals, pirates, and black marketeers. +1 Influence with criminal contacts.", "benefit": "Prerequisites: Fel 30 | Tier 1 | Aptitudes: Fellowship, Social"}}
{"_id": "rt_t003", "name": "Peer (Xenos)", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Fel 30", "aptitudes": ["Fellowship", "Social"], "tier": 1, "description": "+10 Fellowship tests with non-hostile xenos species. May attempt Charm/Inquiry on xenos who would otherwise refuse.", "benefit": "Prerequisites: Fel 30 | Tier 1 | Aptitudes: Fellowship, Social"}}
{"_id": "rt_t004", "name": "Warp Eye", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Psy Rating, Navigator", "aptitudes": ["Willpower", "Psyker"], "tier": 2, "description": "Navigator only. Third eye emits warp beam: 1d10+WPB Energy, Pen WPB, 15m range, once per encounter.", "benefit": "Prerequisites: Psy Rating, Navigator | Tier 2 | Aptitudes: Willpower, Psyker"}}
{"_id": "rt_t005", "name": "Navis Nobilite", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Navigator only", "aptitudes": ["Perception", "Psyker"], "tier": 1, "description": "Member of a Navigator House. Access to Navigator powers. Must conceal warp eye in polite company.", "benefit": "Prerequisites: Navigator only | Tier 1 | Aptitudes: Perception, Psyker"}}
{"_id": "rt_t006", "name": "Dynasty Heirloom", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "-", "aptitudes": ["General", "Social"], "tier": 1, "description": "Possess an item of great personal and dynasty value. Once per session, may call upon dynasty contacts for a favour.", "benefit": "Prerequisites: - | Tier 1 | Aptitudes: General, Social"}}
{"_id": "rt_t007", "name": "Grand Endeavour", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Fel 40, Command", "aptitudes": ["Fellowship", "Leadership"], "tier": 3, "description": "Inspire a fleet-wide Endeavour. Once per Endeavour, all participants gain +5 to all tests toward the Endeavour goal.", "benefit": "Prerequisites: Fel 40, Command | Tier 3 | Aptitudes: Fellowship, Leadership"}}
{"_id": "rt_t008", "name": "Master Trader", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Commerce +10, Fel 35", "aptitudes": ["Fellowship", "Social"], "tier": 2, "description": "+20 Commerce tests for major transactions. May add Fellowship bonus to Profit Factor rolls.", "benefit": "Prerequisites: Commerce +10, Fel 35 | Tier 2 | Aptitudes: Fellowship, Social"}}
{"_id": "rt_t009", "name": "Corsair", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Ag 35, Dodge", "aptitudes": ["Agility", "Offence"], "tier": 2, "description": "When aboard ships or in zero-gravity, gain +10 WS and BS. May Dodge as a Free Action once per round in zero-gravity.", "benefit": "Prerequisites: Ag 35, Dodge | Tier 2 | Aptitudes: Agility, Offence"}}
{"_id": "rt_t010", "name": "Renowned Warrant", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Fel 40", "aptitudes": ["Fellowship", "Social"], "tier": 3, "description": "The Rogue Trader's Warrant is famous. +20 Fellowship with Imperial officials. May demand hospitality from any Imperial world governor.", "benefit": "Prerequisites: Fel 40 | Tier 3 | Aptitudes: Fellowship, Social"}}
{"_id": "rt_t011", "name": "Xenophile", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Fel 30, Peer (Xenos)", "aptitudes": ["Fellowship", "Social"], "tier": 2, "description": "Reduce all penalties for interacting with xenos by 20. May attempt to learn xenos languages in hours rather than days.", "benefit": "Prerequisites: Fel 30, Peer (Xenos) | Tier 2 | Aptitudes: Fellowship, Social"}}
{"_id": "rt_t012", "name": "Void Born Warrior", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Void Acclimatised", "aptitudes": ["Agility", "Offence"], "tier": 2, "description": "In zero-gravity and aboard ships: +10 WS, +10 BS. Enemies suffer -10 WS against you in zero-gravity.", "benefit": "Prerequisites: Void Acclimatised | Tier 2 | Aptitudes: Agility, Offence"}}
{"_id": "rt_t013", "name": "Xenos Weapon Training", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "-", "aptitudes": ["Intelligence", "Finesse"], "tier": 1, "description": "Gain proficiency with weapons from one specific xenos species without suffering unfamiliar weapon penalty.", "benefit": "Prerequisites: - | Tier 1 | Aptitudes: Intelligence, Finesse"}}
{"_id": "rt_t014", "name": "Profit Factor", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Fellowship", "aptitudes": ["Fellowship", "Social"], "tier": 1, "description": "Represents the Rogue Trader's wealth and influence. Used for Acquisition tests. Starting value set by GM (typically 40-60).", "benefit": "Prerequisites: Fellowship | Tier 1 | Aptitudes: Fellowship, Social"}}
{"_id": "rt_t015", "name": "Acquisition Test", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "-", "aptitudes": ["Intelligence", "Knowledge"], "tier": 1, "description": "Use Profit Factor + modifiers to acquire items. Availability sets difficulty. Items above Profit Factor may be impossible.", "benefit": "Prerequisites: - | Tier 1 | Aptitudes: Intelligence, Knowledge"}}
