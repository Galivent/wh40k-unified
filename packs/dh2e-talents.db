{"_id": "t065", "name": "Hammer Blow", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Crushing Blow", "aptitudes": ["Strength", "Offence"], "tier": 3, "description": "All Out Attack single strike: add half Strength bonus to Penetration. Attack gains Concussive (2).", "benefit": "Prerequisites: Crushing Blow | Tier 3 | Aptitudes: Strength, Offence"}}
