{"_id": "t031", "name": "Combat Master", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "WS 30", "aptitudes": ["Weapon Skill", "Defence"], "tier": 2, "description": "Opponents get no bonus for outnumbering the character in melee.", "benefit": "Prerequisites: WS 30 | Tier 2 | Aptitudes: Weapon Skill, Defence"}}
