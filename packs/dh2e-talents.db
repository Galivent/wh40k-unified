{"_id": "t018", "name": "Resistance (choose)", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "-", "aptitudes": ["Toughness", "Defence"], "tier": 1, "description": "Gain +10 bonus to a particular resistance test (Fear, Psychic Powers, Poisons, etc.).", "benefit": "Prerequisites: - | Tier 1 | Aptitudes: Toughness, Defence"}}
{"_id": "t019", "name": "Sound Constitution", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "-", "aptitudes": ["Toughness", "General"], "tier": 1, "description": "Gain one additional Wound. May be taken multiple times.", "benefit": "Prerequisites: - | Tier 1 | Aptitudes: Toughness, General"}}
{"_id": "t020", "name": "Takedown", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "-", "aptitudes": ["Weapon Skill", "Offence"], "tier": 1, "description": "Make a special attack to Stun the opponent instead of dealing damage.", "benefit": "Prerequisites: - | Tier 1 | Aptitudes: Weapon Skill, Offence"}}
{"_id": "t021", "name": "Technical Knock", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Int 30", "aptitudes": ["Intelligence", "Tech"], "tier": 1, "description": "Un-jam a gun as a Half Action.", "benefit": "Prerequisites: Int 30 | Tier 1 | Aptitudes: Intelligence, Tech"}}
{"_id": "t022", "name": "Warp Sense", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Psy Rating, Psyniscience, Per 30", "aptitudes": ["Perception", "Psyker"], "tier": 1, "description": "Allows Psyniscience test as a Free Action.", "benefit": "Prerequisites: Psy Rating, Psyniscience, Per 30 | Tier 1 | Aptitudes: Perception, Psyker"}}
{"_id": "t023", "name": "Weapon Training (choose)", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "-", "aptitudes": ["General", "Finesse"], "tier": 1, "description": "Use weapons of chosen Group without penalty. Groups: Las, Solid Projectile, Flame, Plasma, Melta, Bolt, Low-Tech, Chain, Shock, Power, Exotic.", "benefit": "Prerequisites: - | Tier 1 | Aptitudes: General, Finesse"}}
{"_id": "t024", "name": "Weapon-Tech", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Tech-Use +10, Int 40", "aptitudes": ["Intelligence", "Tech"], "tier": 1, "description": "Once per encounter enhance any Melta/Plasma/Power/Exotic weapon: increase damage and penetration by Int bonus until end of round.", "benefit": "Prerequisites: Tech-Use +10, Int 40 | Tier 1 | Aptitudes: Intelligence, Tech"}}
{"_id": "t025", "name": "Enemy (choose)", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "-", "aptitudes": ["General", "Social"], "tier": 1, "description": "Suffer -10 times X penalty to Fellowship and Influence tests with chosen group.", "benefit": "Prerequisites: - | Tier 1 | Aptitudes: General, Social"}}
{"_id": "t026", "name": "Flagellant", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "WP 30", "aptitudes": ["Offence", "Toughness"], "tier": 1, "description": "Full Action: take 1d5-2 Fatigue (min 1) to gain +10 to WP tests vs Fear/Pinning/psychic powers/Corruption for one hour.", "benefit": "Prerequisites: WP 30 | Tier 1 | Aptitudes: Offence, Toughness"}}
{"_id": "t027", "name": "Grenadier", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "BS 35", "aptitudes": ["Ballistic Skill", "Finesse"], "tier": 1, "description": "When missing with thrown/Blast weapon, reduce scatter by up to half BS bonus in metres.", "benefit": "Prerequisites: BS 35 | Tier 1 | Aptitudes: Ballistic Skill, Finesse"}}
