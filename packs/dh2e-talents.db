{"_id": "t051", "name": "Warp Conduit", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Psy Rating, Strong Minded, WP 50", "aptitudes": ["Willpower", "Psyker"], "tier": 2, "description": "Spend Fate point to add 1d5 to psy rating, but add +30 to Psychic Phenomena rolls.", "benefit": "Prerequisites: Psy Rating, Strong Minded, WP 50 | Tier 2 | Aptitudes: Willpower, Psyker"}}
{"_id": "t052", "name": "Whirlwind of Death", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "WS 40", "aptitudes": ["Weapon Skill", "Finesse"], "tier": 2, "description": "Half Action: make one Standard Attack plus one additional attack per extra foe in melee (up to WS bonus total).", "benefit": "Prerequisites: WS 40 | Tier 2 | Aptitudes: Weapon Skill, Finesse"}}
{"_id": "t053", "name": "Witch Finder", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Forbidden Lore (Psykers), WP 45", "aptitudes": ["Knowledge", "Perception"], "tier": 2, "description": "Counts as having Psyniscience at Rank 1 even without being a psyker.", "benefit": "Prerequisites: Forbidden Lore (Psykers), WP 45 | Tier 2 | Aptitudes: Knowledge, Perception"}}
{"_id": "t054", "name": "Face in a Crowd", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Fel 35, Clues from the Crowds", "aptitudes": ["Fellowship", "Social"], "tier": 2, "description": "Use Fellowship instead of Agility when Shadowing a target.", "benefit": "Prerequisites: Fel 35, Clues from the Crowds | Tier 2 | Aptitudes: Fellowship, Social"}}
{"_id": "t055", "name": "Inescapable Attack (choose)", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "BS 40 or WS 40, Per 35", "aptitudes": ["Weapon Skill", "Finesse"], "tier": 2, "description": "Impose penalty on all evasion attempts equal to 10 times the DoS scored on the attack test.", "benefit": "Prerequisites: BS 40 or WS 40, Per 35 | Tier 2 | Aptitudes: Weapon Skill, Finesse"}}
{"_id": "t056", "name": "Adamantium Faith", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Jaded, Resistance (Fear), WP 45", "aptitudes": ["Willpower", "Defence"], "tier": 3, "description": "Subtract WP bonus from DoF on failed Fear or Pinning test. If reduced to 0 or less, counts as passing with 1 DoS.", "benefit": "Prerequisites: Jaded, Resistance (Fear), WP 45 | Tier 3 | Aptitudes: Willpower, Defence"}}
{"_id": "t057", "name": "Assassin Strike", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Ag 40, Acrobatics", "aptitudes": ["Weapon Skill", "Fieldcraft"], "tier": 3, "description": "After melee attack, pass Acrobatics to move at half rate as Free Action. Opponent gets no free attack.", "benefit": "Prerequisites: Ag 40, Acrobatics | Tier 3 | Aptitudes: Weapon Skill, Fieldcraft"}}
{"_id": "t058", "name": "Bastion of Iron Will", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Psy Rating, Strong Minded, WP 40", "aptitudes": ["Willpower", "Psyker"], "tier": 3, "description": "Add 5 x psy rating to any Opposed test when defending against psychic powers.", "benefit": "Prerequisites: Psy Rating, Strong Minded, WP 40 | Tier 3 | Aptitudes: Willpower, Psyker"}}
{"_id": "t059", "name": "Blademaster", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "WS 30, Weapon Training (any Melee)", "aptitudes": ["Weapon Skill", "Finesse"], "tier": 3, "description": "When attacking with any bladed weapon, can re-roll one missed attack per round.", "benefit": "Prerequisites: WS 30, Weapon Training (any Melee) | Tier 3 | Aptitudes: Weapon Skill, Finesse"}}
{"_id": "t060", "name": "Crushing Blow", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "WS 40", "aptitudes": ["Weapon Skill", "Offence"], "tier": 3, "description": "Add half WS bonus (rounded up) to damage inflicted in melee.", "benefit": "Prerequisites: WS 40 | Tier 3 | Aptitudes: Weapon Skill, Offence"}}
{"_id": "t061", "name": "Deathdealer", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "BS 45 or WS 45", "aptitudes": ["Perception", "Finesse"], "tier": 3, "description": "Attacks in chosen combat type that inflict Critical damage add Perception bonus to the damage result.", "benefit": "Prerequisites: BS 45 or WS 45 | Tier 3 | Aptitudes: Perception, Finesse"}}
{"_id": "t062", "name": "Eye of Vengeance", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "BS 50", "aptitudes": ["Ballistic Skill", "Offence"], "tier": 3, "description": "Spend 1 Fate point to add the DoS scored on attack test to both damage and Penetration.", "benefit": "Prerequisites: BS 50 | Tier 3 | Aptitudes: Ballistic Skill, Offence"}}
