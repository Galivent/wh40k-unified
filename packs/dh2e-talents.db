{"_id": "t001", "name": "Ambidextrous", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Ag 30", "aptitudes": ["Weapon Skill", "Ballistic Skill"], "tier": 1, "description": "When combined with Two-Weapon Wielder, penalty for attacks with both weapons drops to -10.", "benefit": "Prerequisites: Ag 30 | Tier 1 | Aptitudes: Weapon Skill, Ballistic Skill"}}
{"_id": "t002", "name": "Blind Fighting", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Per 30", "aptitudes": ["Perception", "Fieldcraft"], "tier": 1, "description": "Ignores all penalties for fighting in melee while suffering from obscured vision.", "benefit": "Prerequisites: Per 30 | Tier 1 | Aptitudes: Perception, Fieldcraft"}}
{"_id": "t003", "name": "Bodyguard", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Ag 35", "aptitudes": ["Agility", "Defence"], "tier": 1, "description": "After enemy attacks ally: use Reaction to move up to Half Move and interpose. Attack resolves against you. May also Parry as part of the Reaction in melee.", "benefit": "Prerequisites: Ag 35 | Tier 1 | Aptitudes: Agility, Defence"}}
{"_id": "t004", "name": "Catfall", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Ag 30", "aptitudes": ["Agility", "Fieldcraft"], "tier": 1, "description": "Reduces effective fall distance by metres equal to Agility bonus. +20 to Acrobatics when using Jump.", "benefit": "Prerequisites: Ag 30 | Tier 1 | Aptitudes: Agility, Fieldcraft"}}
{"_id": "t005", "name": "Clues from the Crowds", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Fel 30", "aptitudes": ["General", "Social"], "tier": 1, "description": "Once per day, re-roll a test made to gather information from a group of people.", "benefit": "Prerequisites: Fel 30 | Tier 1 | Aptitudes: General, Social"}}
{"_id": "t006", "name": "Die Hard", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "WP 40", "aptitudes": ["Willpower", "Defence"], "tier": 1, "description": "Test Challenging (+0) Willpower to avoid Fatigue from Blood Loss.", "benefit": "Prerequisites: WP 40 | Tier 1 | Aptitudes: Willpower, Defence"}}
{"_id": "t007", "name": "Disarm", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Ag 30", "aptitudes": ["Weapon Skill", "Defence"], "tier": 1, "description": "Full Action: Opposed WS test to force opponent to drop weapon. 3+ DoS: steal the weapon.", "benefit": "Prerequisites: Ag 30 | Tier 1 | Aptitudes: Weapon Skill, Defence"}}
{"_id": "t008", "name": "Double Team", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "-", "aptitudes": ["General", "Offence"], "tier": 1, "description": "Gain additional +10 for outnumbering an opponent in melee.", "benefit": "Prerequisites: - | Tier 1 | Aptitudes: General, Offence"}}
{"_id": "t009", "name": "Frenzy", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "-", "aptitudes": ["Strength", "Offence"], "tier": 1, "description": "Full round to enter Frenzy: +10 WS/S/T/WP, -20 BS/Int/Fel, immune to Fear/Pinning/Stunning. Cannot Parry, retreat, or flee.", "benefit": "Prerequisites: - | Tier 1 | Aptitudes: Strength, Offence"}}
{"_id": "t010", "name": "Iron Jaw", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "T 40", "aptitudes": ["Toughness", "Defence"], "tier": 1, "description": "Test Challenging (+0) Toughness to overcome Stunning.", "benefit": "Prerequisites: T 40 | Tier 1 | Aptitudes: Toughness, Defence"}}
{"_id": "t011", "name": "Jaded", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "WP 40", "aptitudes": ["Willpower", "Defence"], "tier": 1, "description": "Mundane horrors do not cause Insanity or Fear rolls. Daemons and Warp manifestations still apply.", "benefit": "Prerequisites: WP 40 | Tier 1 | Aptitudes: Willpower, Defence"}}
{"_id": "t012", "name": "Keen Intuition", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Int 35", "aptitudes": ["Perception", "Social"], "tier": 1, "description": "Can retry a failed Awareness test once with -10 modifier.", "benefit": "Prerequisites: Int 35 | Tier 1 | Aptitudes: Perception, Social"}}
{"_id": "t013", "name": "Leap Up", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Ag 30", "aptitudes": ["Agility", "General"], "tier": 1, "description": "Stand up from Prone as a Free Action.", "benefit": "Prerequisites: Ag 30 | Tier 1 | Aptitudes: Agility, General"}}
{"_id": "t014", "name": "Nowhere to Hide", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Per 30", "aptitudes": ["Perception", "Offence"], "tier": 1, "description": "Add DoS from attack roll to reduce the Armour value of cover.", "benefit": "Prerequisites: Per 30 | Tier 1 | Aptitudes: Perception, Offence"}}
{"_id": "t015", "name": "Peer (choose)", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Fel 30", "aptitudes": ["Fellowship", "Social"], "tier": 1, "description": "Good reputation with chosen group: +10 times X to Fellowship tests. Also increases Influence by 1.", "benefit": "Prerequisites: Fel 30 | Tier 1 | Aptitudes: Fellowship, Social"}}
