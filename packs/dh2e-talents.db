{"_id": "t035", "name": "Deny the Witch", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "WP 35", "aptitudes": ["Willpower", "Defence"], "tier": 2, "description": "Can use Willpower to Evade against psychic attacks.", "benefit": "Prerequisites: WP 35 | Tier 2 | Aptitudes: Willpower, Defence"}}
