{"_id": "t038", "name": "Hard Target", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Ag 40", "aptitudes": ["Agility", "Defence"], "tier": 2, "description": "-20 to hit the character when he Charges or Runs.", "benefit": "Prerequisites: Ag 40 | Tier 2 | Aptitudes: Agility, Defence"}}
{"_id": "t039", "name": "Hardy", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "T 40", "aptitudes": ["Toughness", "Defence"], "tier": 2, "description": "Character always heals as if Lightly Damaged, regardless of actual damage level.", "benefit": "Prerequisites: T 40 | Tier 2 | Aptitudes: Toughness, Defence"}}
{"_id": "t040", "name": "Hatred (choose)", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "-", "aptitudes": ["Weapon Skill", "Social"], "tier": 2, "description": "+10 to attack WS tests against chosen group. Must pass WP test to retreat or surrender against them.", "benefit": "Prerequisites: - | Tier 2 | Aptitudes: Weapon Skill, Social"}}
{"_id": "t041", "name": "Hip Shooting", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "BS 40, Ag 40", "aptitudes": ["Ballistic Skill", "Finesse"], "tier": 2, "description": "Full Action: move up to Full Move and make a single shot attack with a ranged weapon.", "benefit": "Prerequisites: BS 40, Ag 40 | Tier 2 | Aptitudes: Ballistic Skill, Finesse"}}
{"_id": "t042", "name": "Independent Targeting", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "BS 40", "aptitudes": ["Ballistic Skill", "Finesse"], "tier": 2, "description": "Fire at multiple targets more than 10 metres apart when firing two weapons simultaneously.", "benefit": "Prerequisites: BS 40 | Tier 2 | Aptitudes: Ballistic Skill, Finesse"}}
{"_id": "t043", "name": "Killing Strike", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "WS 50", "aptitudes": ["Weapon Skill", "Offence"], "tier": 2, "description": "Spend a Fate point to make melee attacks unavoidable (cannot be Dodged or Parried).", "benefit": "Prerequisites: WS 50 | Tier 2 | Aptitudes: Weapon Skill, Offence"}}
{"_id": "t044", "name": "Marksman", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "BS 35", "aptitudes": ["Ballistic Skill", "Finesse"], "tier": 2, "description": "No penalties for firing at long or extreme range.", "benefit": "Prerequisites: BS 35 | Tier 2 | Aptitudes: Ballistic Skill, Finesse"}}
{"_id": "t045", "name": "Mechadendrite Use (choose)", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Mechanicus Implants", "aptitudes": ["Intelligence", "Tech"], "tier": 2, "description": "Gain ability to use Weapon or Utility Mechadendrites.", "benefit": "Prerequisites: Mechanicus Implants | Tier 2 | Aptitudes: Intelligence, Tech"}}
