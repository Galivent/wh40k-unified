{"_id": "t029", "name": "Battle Rage", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Frenzy", "aptitudes": ["Strength", "Defence"], "tier": 2, "description": "Can Parry while Frenzied. Can re-roll a failed test to snap out of or resist entering Frenzy.", "benefit": "Prerequisites: Frenzy | Tier 2 | Aptitudes: Strength, Defence"}}
