{"_id": "sk001", "name": "Acrobatics", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Agility", "aptitudes": ["Agility", "General"], "tier": 0, "description": "Keep balance, avoid falling, jump, move around obstacles. Special: Contortionist (escape bonds), Manoeuvring (Disengage as Half Action), Jumping.", "benefit": "Linked: Agility | Time: Full Action | Aptitudes: Agility, General"}}
{"_id": "sk002", "name": "Athletics", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Strength", "aptitudes": ["Strength", "General"], "tier": 0, "description": "Swim, climb, push beyond limits. Special: Endurance (ignore Fatigue from running/swimming/climbing), Heft (increase carrying capacity).", "benefit": "Linked: Strength | Time: Full Action | Aptitudes: Strength, General"}}
{"_id": "sk003", "name": "Awareness", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Perception", "aptitudes": ["Perception", "Fieldcraft"], "tier": 0, "description": "Spot ambushes, search for hidden items, eavesdrop. Special: Lip Reading (-10 per 10m).", "benefit": "Linked: Perception | Time: Free Action | Aptitudes: Perception, Fieldcraft"}}
{"_id": "sk004", "name": "Charm", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Fellowship", "aptitudes": ["Fellowship", "Social"], "tier": 0, "description": "Improve NPC opinion, distract, gather information. Target makes WP save to resist.", "benefit": "Linked: Fellowship | Time: 1 minute | Aptitudes: Fellowship, Social"}}
{"_id": "sk005", "name": "Command", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Fellowship", "aptitudes": ["Fellowship", "Leadership"], "tier": 0, "description": "Send NPCs into danger, rally forces, organise against surprise. Special: Inspire (+10 ally next test), Terrify (counter Fear).", "benefit": "Linked: Fellowship | Time: Half/Full | Aptitudes: Fellowship, Leadership"}}
{"_id": "sk006", "name": "Commerce", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Intelligence", "aptitudes": ["Intelligence", "Knowledge"], "tier": 0, "description": "Gain bonus on Requisition, track rare items, ascertain value. Special: Evaluate (determine Availability).", "benefit": "Linked: Intelligence | Time: 1 minute+ | Aptitudes: Intelligence, Knowledge"}}
{"_id": "sk007", "name": "Common Lore", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Intelligence", "aptitudes": ["Intelligence", "General"], "tier": 0, "description": "Learn about situations, locations, characters. Specialisations: Adeptus Mechanicus, Imperial Guard, Underworld, War, etc.", "benefit": "Linked: Intelligence | Time: Free Action | Aptitudes: Intelligence, General"}}
{"_id": "sk008", "name": "Deceive", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Fellowship", "aptitudes": ["Fellowship", "Social"], "tier": 0, "description": "Tell convincing lies, distract, create disguise. Special: Disguise (create disguises given time and materials).", "benefit": "Linked: Fellowship | Time: 1 minute+ | Aptitudes: Fellowship, Social"}}
{"_id": "sk009", "name": "Dodge", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Agility", "aptitudes": ["Agility", "Defence"], "tier": 0, "description": "Dodge melee or ranged attacks, avoid hazards. Special: Dive for Cover (leap behind cover as Reaction).", "benefit": "Linked: Agility | Time: Reaction | Aptitudes: Agility, Defence"}}
{"_id": "sk010", "name": "Forbidden Lore", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Intelligence", "aptitudes": ["Intelligence", "Knowledge"], "tier": 0, "description": "Cult activity, xenos operations, daemonic summoning. Specialisations: Daemonology, Psykers, Warp, Xenos, Heresy, etc.", "benefit": "Linked: Intelligence | Time: Free Action | Aptitudes: Intelligence, Knowledge"}}
{"_id": "sk011", "name": "Inquiry", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Fellowship", "aptitudes": ["Fellowship", "Social"], "tier": 0, "description": "Track down criminals, learn attitudes of local populace, gather information about locations.", "benefit": "Linked: Fellowship | Time: 1 hour+ | Aptitudes: Fellowship, Social"}}
{"_id": "sk012", "name": "Interrogation", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Willpower", "aptitudes": ["Willpower", "Social"], "tier": 0, "description": "Extract information from prisoners. Opposed by target's WP.", "benefit": "Linked: Willpower | Time: 1 hour+ | Aptitudes: Willpower, Social"}}
{"_id": "sk013", "name": "Intimidate", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Strength", "aptitudes": ["Strength", "Social"], "tier": 0, "description": "Coerce someone into acting a certain way, make opponent back down.", "benefit": "Linked: Strength | Time: Full Action | Aptitudes: Strength, Social"}}
{"_id": "sk014", "name": "Linguistics", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Intelligence", "aptitudes": ["Intelligence", "General"], "tier": 0, "description": "Decipher archaic text, compose prose, convey messages. Specialisations: High Gothic, Low Gothic, Xenos languages.", "benefit": "Linked: Intelligence | Time: Free Action | Aptitudes: Intelligence, General"}}
{"_id": "sk015", "name": "Logic", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Intelligence", "aptitudes": ["Intelligence", "Knowledge"], "tier": 0, "description": "Solve riddles, find clues, win games of chance. Special: Gambling (Opposed Logic), Ciphers (unravel codes).", "benefit": "Linked: Intelligence | Time: 1 minute+ | Aptitudes: Intelligence, Knowledge"}}
{"_id": "sk016", "name": "Medicae", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Intelligence", "aptitudes": ["Intelligence", "Fieldcraft"], "tier": 0, "description": "Apply first aid, diagnose afflictions, perform surgery. Special: First Aid (remove IB+DoS damage), Extended Care, Diagnose.", "benefit": "Linked: Intelligence | Time: Full Action | Aptitudes: Intelligence, Fieldcraft"}}
{"_id": "sk017", "name": "Navigate (Surface)", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Intelligence", "aptitudes": ["Intelligence", "Fieldcraft"], "tier": 0, "description": "Journey across unfamiliar terrain, find bearings, create maps. Used on planetary surfaces.", "benefit": "Linked: Intelligence | Time: Variable | Aptitudes: Intelligence, Fieldcraft"}}
{"_id": "sk018", "name": "Navigate (Stellar)", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Intelligence", "aptitudes": ["Intelligence", "Fieldcraft"], "tier": 0, "description": "Journey within a star system, find stranded ships, plot routes between planetary bodies.", "benefit": "Linked: Intelligence | Time: Variable | Aptitudes: Intelligence, Fieldcraft"}}
{"_id": "sk019", "name": "Navigate (Warp)", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Intelligence", "aptitudes": ["Intelligence", "Fieldcraft"], "tier": 0, "description": "Guide a starship through the Warp. Critical for void travel. Navigator only normally.", "benefit": "Linked: Intelligence | Time: Variable | Aptitudes: Intelligence, Fieldcraft"}}
{"_id": "sk020", "name": "Operate (Surface)", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Agility", "aptitudes": ["Agility", "Fieldcraft"], "tier": 0, "description": "Drive a vehicle in combat, push beyond limits, manoeuvre through terrain.", "benefit": "Linked: Agility | Time: Half Action | Aptitudes: Agility, Fieldcraft"}}
{"_id": "sk021", "name": "Operate (Aeronautica)", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Agility", "aptitudes": ["Agility", "Fieldcraft"], "tier": 0, "description": "Pilot aircraft in combat, fly beyond limits, land on difficult terrain.", "benefit": "Linked: Agility | Time: Half Action | Aptitudes: Agility, Fieldcraft"}}
{"_id": "sk022", "name": "Operate (Voidship)", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Agility", "aptitudes": ["Agility", "Fieldcraft"], "tier": 0, "description": "Manoeuvre a voidship, oversee macrobattery or ship weapon fire.", "benefit": "Linked: Agility | Time: Half Action | Aptitudes: Agility, Fieldcraft"}}
{"_id": "sk023", "name": "Parry", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Weapon Skill", "aptitudes": ["Weapon Skill", "Defence"], "tier": 0, "description": "Attempt to deflect blows in melee combat.", "benefit": "Linked: Weapon Skill | Time: Reaction | Aptitudes: Weapon Skill, Defence"}}
{"_id": "sk024", "name": "Psyniscience", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Perception", "aptitudes": ["Perception", "Psyker"], "tier": 0, "description": "Hunt for daemons, detect psychic powers, determine thin points in the Warp veil.", "benefit": "Linked: Perception | Time: Half Action | Aptitudes: Perception, Psyker"}}
{"_id": "sk025", "name": "Scholastic Lore", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Intelligence", "aptitudes": ["Intelligence", "Knowledge"], "tier": 0, "description": "Recount legends, understand obscure law, identify rare beasts. Specialisations: Astromancy, Beasts, Bureaucracy, Chymistry, Cryptology, Heraldry, Imperial Warrants, Judgement, Legend, Navis Nobilite, Numerology, Occult, Philosophy, Tactica Imperialis.", "benefit": "Linked: Intelligence | Time: Free Action | Aptitudes: Intelligence, Knowledge"}}
{"_id": "sk026", "name": "Scrutiny", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Perception", "aptitudes": ["Perception", "General"], "tier": 0, "description": "Tell if someone is lying, collate information, interpret augur and auspex readings.", "benefit": "Linked: Perception | Time: Half Action | Aptitudes: Perception, General"}}
{"_id": "sk027", "name": "Security", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Intelligence", "aptitudes": ["Intelligence", "Tech"], "tier": 0, "description": "Open locked doors, break into cogitators, lay traps. Special: Traps (fashion and set traps).", "benefit": "Linked: Intelligence | Time: 1 minute | Aptitudes: Intelligence, Tech"}}
{"_id": "sk028", "name": "Sleight of Hand", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Agility", "aptitudes": ["Agility", "Knowledge"], "tier": 0, "description": "Steal from pockets, palm evidence, plant items on suspects.", "benefit": "Linked: Agility | Time: Half/Free | Aptitudes: Agility, Knowledge"}}
{"_id": "sk029", "name": "Stealth", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Agility", "aptitudes": ["Agility", "Fieldcraft"], "tier": 0, "description": "Scout without detection, sneak quietly, follow someone unseen. Special: Shadowing (follow unseen 5 min per DoS).", "benefit": "Linked: Agility | Time: Free Action | Aptitudes: Agility, Fieldcraft"}}
{"_id": "sk030", "name": "Survival", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Perception", "aptitudes": ["Perception", "Fieldcraft"], "tier": 0, "description": "Find food/water in hostile environments, start fires, track foes. Special: Crafting, Tracking, Wrangling.", "benefit": "Linked: Perception | Time: Full Action | Aptitudes: Perception, Fieldcraft"}}
{"_id": "sk031", "name": "Tech-Use", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Intelligence", "aptitudes": ["Intelligence", "Tech"], "tier": 0, "description": "Repair broken equipment, push technology beyond limits, use unknown technology. Special: Crafting, Demolitions.", "benefit": "Linked: Intelligence | Time: 1 minute+ | Aptitudes: Intelligence, Tech"}}
{"_id": "sk032", "name": "Trade", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "skill", "prerequisites": "Characteristic: Intelligence", "aptitudes": ["Intelligence", "General"], "tier": 0, "description": "Prepare meals, carve sigils, uncover lost colonies. Specialisations: Armourer, Chymist, Cryptographer, Linguist, Shipwright, Voidfarer, etc.", "benefit": "Linked: Intelligence | Time: Variable | Aptitudes: Intelligence, General"}}
