{"_id": "tr001", "name": "Amorphous", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "May increase or decrease Size trait by 1 as Free Action. Also has the Crawler trait.", "benefit": "May increase or decrease Size trait by 1 as Free Action. Also has the Crawler trait."}}
{"_id": "tr002", "name": "Amphibious", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Creature can breathe underwater indefinitely.", "benefit": "Creature can breathe underwater indefinitely."}}
{"_id": "tr003", "name": "Auto-stabilized", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Always counts as braced for Heavy weapons. Never needs to brace.", "benefit": "Always counts as braced for Heavy weapons. Never needs to brace."}}
{"_id": "tr004", "name": "Baneful Presence (X)", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "All within X metres suffer -10 to Willpower tests.", "benefit": "All within X metres suffer -10 to Willpower tests."}}
{"_id": "tr005", "name": "Bestial", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Automatically passes Survival tests. Must pass WP test when frightened or injured or it flees.", "benefit": "Automatically passes Survival tests. Must pass WP test when frightened or injured or it flees."}}
{"_id": "tr006", "name": "Blind", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Cannot see. Blind Fighting talent reduces WS penalty from -30 to -15.", "benefit": "Cannot see. Blind Fighting talent reduces WS penalty from -30 to -15."}}
{"_id": "tr007", "name": "Brutal Charge (X)", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Deals extra X damage on each hit when performing a Charge action.", "benefit": "Deals extra X damage on each hit when performing a Charge action."}}
{"_id": "tr008", "name": "Burrower (X)", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Speed X when burrowing through soil or rock. Leaves a tunnel behind.", "benefit": "Speed X when burrowing through soil or rock. Leaves a tunnel behind."}}
{"_id": "tr009", "name": "Crawler", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Base move is half normal (rounded up). Does not take penalties for difficult terrain.", "benefit": "Base move is half normal (rounded up). Does not take penalties for difficult terrain."}}
{"_id": "tr010", "name": "Daemonic (X)", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Increase Toughness bonus vs all damage by X. Negated by force weapons, psychic powers, holy attacks.", "benefit": "Increase Toughness bonus vs all damage by X. Negated by force weapons, psychic powers, holy attacks."}}
{"_id": "tr011", "name": "Dark-sight", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Can see in complete darkness. Never takes penalties for dim or no lighting.", "benefit": "Can see in complete darkness. Never takes penalties for dim or no lighting."}}
{"_id": "tr012", "name": "Deadly Natural Weapons", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "As Natural Weapons but attacks are not Primitive.", "benefit": "As Natural Weapons but attacks are not Primitive."}}
{"_id": "tr013", "name": "Fear (X)", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Encounter triggers WP test with penalty based on rating 1-4. Failure causes roll on Shock table +10 per DoF.", "benefit": "Encounter triggers WP test with penalty based on rating 1-4. Failure causes roll on Shock table +10 per DoF."}}
{"_id": "tr014", "name": "Flyer (X)", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Can fly at speed X. Replaces Agility bonus for movement while airborne.", "benefit": "Can fly at speed X. Replaces Agility bonus for movement while airborne."}}
{"_id": "tr015", "name": "From Beyond", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Immune to Fear, Pinning, Insanity, and mind-altering psychic powers.", "benefit": "Immune to Fear, Pinning, Insanity, and mind-altering psychic powers."}}
{"_id": "tr016", "name": "Hoverer (X)", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Fly up to 2 metres altitude at speed X.", "benefit": "Fly up to 2 metres altitude at speed X."}}
{"_id": "tr017", "name": "Incorporeal", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Immune to normal weapons. Gains Hoverer (6) and +30 Stealth. Only hurt by Daemons, psychic powers, Warp creatures, or force weapons.", "benefit": "Immune to normal weapons. Gains Hoverer (6) and +30 Stealth. Only hurt by Daemons, psychic powers, Warp creatures, or force weapons."}}
{"_id": "tr018", "name": "Machine (X)", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Does not breathe, immune to vacuum, cold, and mind-influencing effects. Has X Armour Points stacking with worn armour.", "benefit": "Does not breathe, immune to vacuum, cold, and mind-influencing effects. Has X Armour Points stacking with worn armour."}}
{"_id": "tr019", "name": "Mechanicus Implants", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Has Cranial circuitry, Cyber-mantle, Electro-Graft, Electoo Inductors, and Potenia Coil.", "benefit": "Has Cranial circuitry, Cyber-mantle, Electro-Graft, Electoo Inductors, and Potenia Coil."}}
{"_id": "tr020", "name": "Mind Lock", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Must pass Routine (+20) Intelligence test when faced with unrecognised situation without orders, or be Stunned for 1 round.", "benefit": "Must pass Routine (+20) Intelligence test when faced with unrecognised situation without orders, or be Stunned for 1 round."}}
{"_id": "tr021", "name": "Multiple Arms (X)", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Has X arms total. +10 to climbing/swimming Athletics. Additional melee attacks per pair of extra arms.", "benefit": "Has X arms total. +10 to climbing/swimming Athletics. Additional melee attacks per pair of extra arms."}}
{"_id": "tr022", "name": "Natural Armour (X)", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Gain X Armour Points to all locations. Stacks with worn armour.", "benefit": "Gain X Armour Points to all locations. Stacks with worn armour."}}
{"_id": "tr023", "name": "Natural Weapons", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Counts as armed. Attacks deal 1d10+SB damage. Cannot Parry or be Disarmed. Attacks are Primitive (7) unless stated otherwise.", "benefit": "Counts as armed. Attacks deal 1d10+SB damage. Cannot Parry or be Disarmed. Attacks are Primitive (7) unless stated otherwise."}}
{"_id": "tr024", "name": "Phase", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Can switch between Incorporeal and Corporeal as a Half Action.", "benefit": "Can switch between Incorporeal and Corporeal as a Half Action."}}
{"_id": "tr025", "name": "Psyker", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Has a Psy Rating of 1 or more. Can use psychic powers.", "benefit": "Has a Psy Rating of 1 or more. Can use psychic powers."}}
{"_id": "tr026", "name": "Quadruped", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Movement equals Agility Bonus x2. More than four legs adds +2 further.", "benefit": "Movement equals Agility Bonus x2. More than four legs adds +2 further."}}
{"_id": "tr027", "name": "Regeneration (X)", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "At start of each turn, pass Toughness test to remove X damage.", "benefit": "At start of each turn, pass Toughness test to remove X damage."}}
{"_id": "tr028", "name": "Size (X)", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Determines creature size from 1 (Miniscule) to 8 (Titanic). Affects attack modifiers and movement.", "benefit": "Determines creature size from 1 (Miniscule) to 8 (Titanic). Affects attack modifiers and movement."}}
{"_id": "tr029", "name": "Sonar Sense", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Perceive surroundings within 30 metres. Others can detect on Difficult (-10) Awareness.", "benefit": "Perceive surroundings within 30 metres. Others can detect on Difficult (-10) Awareness."}}
{"_id": "tr030", "name": "Soul Bound", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Bound to a master. Upon binding suffer one of: 3d10 Insanity, permanent blindness, lose 1d10 from one characteristic, or random mutation.", "benefit": "Bound to a master. Upon binding suffer one of: 3d10 Insanity, permanent blindness, lose 1d10 from one characteristic, or random mutation."}}
{"_id": "tr031", "name": "Stampede", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Failed WP causes creature to flee, trampling everything. Anyone in path takes Natural Weapon hit.", "benefit": "Failed WP causes creature to flee, trampling everything. Anyone in path takes Natural Weapon hit."}}
{"_id": "tr032", "name": "Stuff of Nightmares", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Immune to most conditions. Has Undying trait. Ignores Critical Effects unless from psychic power, force weapon, or holy attack.", "benefit": "Immune to most conditions. Has Undying trait. Ignores Critical Effects unless from psychic power, force weapon, or holy attack."}}
{"_id": "tr033", "name": "Sturdy", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "+20 bonus to resist Grapple, Knock Down, and Takedown actions.", "benefit": "+20 bonus to resist Grapple, Knock Down, and Takedown actions."}}
{"_id": "tr034", "name": "Toxic (X)", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Attackers in melee must pass Toughness test at -10xX or suffer 1d10 Energy damage ignoring Armour and Toughness.", "benefit": "Attackers in melee must pass Toughness test at -10xX or suffer 1d10 Energy damage ignoring Armour and Toughness."}}
{"_id": "tr035", "name": "Undying", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Cannot be harmed by disease, poison, or toxic effects. Does not need to breathe. Survives in vacuum.", "benefit": "Cannot be harmed by disease, poison, or toxic effects. Does not need to breathe. Survives in vacuum."}}
{"_id": "tr036", "name": "Unnatural Characteristic (X)", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Increases one characteristic bonus by X. Must specify which characteristic.", "benefit": "Increases one characteristic bonus by X. Must specify which characteristic."}}
{"_id": "tr037", "name": "Unnatural Senses (X)", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Perceive surroundings by uncanny means up to X metres.", "benefit": "Perceive surroundings by uncanny means up to X metres."}}
{"_id": "tr038", "name": "Warp Instability", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "If creature takes damage but deals none by end of next turn, must pass WP or suffer 1 damage per DoF. Destroyed if damage equals Wounds.", "benefit": "If creature takes damage but deals none by end of next turn, must pass WP or suffer 1 damage per DoF. Destroyed if damage equals Wounds."}}
{"_id": "tr039", "name": "Warp Weapons", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "Attacks ignore armour unless created from psychoactive materials or warded against the Warp.", "benefit": "Attacks ignore armour unless created from psychoactive materials or warded against the Warp."}}
{"_id": "tr040", "name": "Touched by the Fates", "type": "trait", "img": "icons/svg/item-bag.svg", "system": {"description": "NPC has Fate points equal to the value of this trait.", "benefit": "NPC has Fate points equal to the value of this trait."}}
