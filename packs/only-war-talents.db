{"_id": "ow_t001", "name": "Air of Authority", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Fel 30", "aptitudes": ["Fellowship", "Leadership"], "tier": 1, "description": "Affect a number of targets equal to 1d10 + Fellowship bonus with a single Command test.", "benefit": "Prerequisites: Fel 30 | Tier 1 | Aptitudes: Fellowship, Leadership"}}
{"_id": "ow_t002", "name": "Combat Formation", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "-", "aptitudes": ["General", "Leadership"], "tier": 1, "description": "Once per encounter, as a Free Action, grant +10 to next action to all allies within 10m who can see and hear you.", "benefit": "Prerequisites: - | Tier 1 | Aptitudes: General, Leadership"}}
{"_id": "ow_t003", "name": "Die Hard", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "WP 40", "aptitudes": ["Willpower", "Defence"], "tier": 1, "description": "Test Challenging (+0) WP to avoid gaining Fatigue from Blood Loss.", "benefit": "Prerequisites: WP 40 | Tier 1 | Aptitudes: Willpower, Defence"}}
{"_id": "ow_t004", "name": "Into the Jaws of Hell", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "-", "aptitudes": ["Willpower", "Defence"], "tier": 1, "description": "Never suffer penalties to Willpower tests caused by the presence of large numbers of enemies.", "benefit": "Prerequisites: - | Tier 1 | Aptitudes: Willpower, Defence"}}
{"_id": "ow_t005", "name": "Nerves of Steel", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "WP 35", "aptitudes": ["Willpower", "Defence"], "tier": 1, "description": "May re-roll failed Pinning tests. If already have this talent, reduce Pinning test difficulty by one step.", "benefit": "Prerequisites: WP 35 | Tier 1 | Aptitudes: Willpower, Defence"}}
{"_id": "ow_t006", "name": "Ambush", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "-", "aptitudes": ["Agility", "Fieldcraft"], "tier": 1, "description": "When making an ambush attack, add an additional +10 to attack rolls on top of Surprise bonus.", "benefit": "Prerequisites: - | Tier 1 | Aptitudes: Agility, Fieldcraft"}}
{"_id": "ow_t007", "name": "Hatred (Enemies of the Imperium)", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "-", "aptitudes": ["Weapon Skill", "Social"], "tier": 2, "description": "+10 to attack WS tests against xenos, heretics, and traitors. Must pass WP test to retreat from them.", "benefit": "Prerequisites: - | Tier 2 | Aptitudes: Weapon Skill, Social"}}
{"_id": "ow_t008", "name": "Coordinated Assault", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Command", "aptitudes": ["Fellowship", "Leadership"], "tier": 2, "description": "As Full Action, grant up to Int bonus allies within earshot one free attack as Reaction this round.", "benefit": "Prerequisites: Command | Tier 2 | Aptitudes: Fellowship, Leadership"}}
{"_id": "ow_t009", "name": "Weight of Fire", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "BS 40", "aptitudes": ["Ballistic Skill", "Offence"], "tier": 2, "description": "When firing Full Auto, add 1 additional hit per 2 DoS instead of per DoS scored.", "benefit": "Prerequisites: BS 40 | Tier 2 | Aptitudes: Ballistic Skill, Offence"}}
{"_id": "ow_t010", "name": "Suppressive Fire", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "BS 35", "aptitudes": ["Ballistic Skill", "Offence"], "tier": 2, "description": "When using Full Auto, enemies in fire zone must test Pinning even if not hit.", "benefit": "Prerequisites: BS 35 | Tier 2 | Aptitudes: Ballistic Skill, Offence"}}
{"_id": "ow_t011", "name": "Demolitions", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Tech-Use, Security", "aptitudes": ["Intelligence", "Tech"], "tier": 2, "description": "Create and defuse explosives. +20 Tech-Use for improvised explosives. Know safe detonation distances.", "benefit": "Prerequisites: Tech-Use, Security | Tier 2 | Aptitudes: Intelligence, Tech"}}
{"_id": "ow_t012", "name": "Field Medic", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Medicae", "aptitudes": ["Intelligence", "Fieldcraft"], "tier": 2, "description": "May attempt First Aid as a Half Action. +10 Medicae during combat.", "benefit": "Prerequisites: Medicae | Tier 2 | Aptitudes: Intelligence, Fieldcraft"}}
{"_id": "ow_t013", "name": "Tank Hunter", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "BS 35 or WS 35", "aptitudes": ["Ballistic Skill", "Offence"], "tier": 2, "description": "Attacks against vehicles ignore 4 points of armour. +10 BS tests against vehicles.", "benefit": "Prerequisites: BS 35 or WS 35 | Tier 2 | Aptitudes: Ballistic Skill, Offence"}}
{"_id": "ow_t014", "name": "Gunner", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Operate (any)", "aptitudes": ["Agility", "Tech"], "tier": 2, "description": "When firing a vehicle weapon, may fire one additional shot per DoS on the Operate test.", "benefit": "Prerequisites: Operate (any) | Tier 2 | Aptitudes: Agility, Tech"}}
{"_id": "ow_t015", "name": "Shield Wall", "type": "talent", "img": "icons/svg/item-bag.svg", "system": {"componentType": "talent", "prerequisites": "Ag 30, Weapon Training (Low-Tech)", "aptitudes": ["Agility", "Defence"], "tier": 2, "description": "When using a shield, enemies have -10 WS vs you. May use shield as cover for adjacent ally.", "benefit": "Prerequisites: Ag 30, Weapon Training (Low-Tech) | Tier 2 | Aptitudes: Agility, Defence"}}
